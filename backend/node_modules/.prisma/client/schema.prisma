// ═══════════════════════════════════════════════════════════════════════════
//  SplitPass — Prisma Schema  (PostgreSQL)
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String    @default("")
  passwordHash  String
  role          String    @default("customer") // customer | moderator | superadmin
  status        String    @default("active") // active | pending | suspended
  newsletter    Boolean   @default(true)
  rejectionNote String?
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  ownedGroups       Group[]            @relation("OrganizerGroups")
  memberships       GroupMember[]
  moderatorSettings ModeratorSettings?
  moderatorPayouts  ModeratorPayout[]  @relation("ModeratorPayouts")
  payments          Payment[]          @relation("UserPayments")

  @@map("users")
}

// ─── Groups ───────────────────────────────────────────────────────────────
model Group {
  id             String    @id @default(uuid())
  serviceId      String
  serviceName    String
  serviceIcon    String
  planName       String
  totalPrice     Float
  maxSlots       Int
  pricePerSlot   Float
  platformFee    Float
  memberPays     Float
  feePercent     Float     @default(8)
  organizerId    String
  organizerName  String
  organizerEmail String
  description    String    @default("")
  billingCycle   String    @default("monthly") // monthly | quarterly | biannually | annually
  status         String    @default("open") // open | full | closed | pending_review
  reviewStatus   String    @default("pending") // pending | approved | rejected
  reviewNote     String    @default("")
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organizer        User              @relation("OrganizerGroups", fields: [organizerId], references: [id])
  members          GroupMember[]
  payments         Payment[]
  pesapalOrders    PesapalOrder[]
  platformEarnings PlatformEarning[]
  credentials      GroupCredential?
  emails           GroupEmail[]

  @@map("groups")
}

// ─── Group Members ────────────────────────────────────────────────────────
model GroupMember {
  id                  String    @id @default(uuid())
  groupId             String
  userId              String
  name                String
  email               String
  role                String    @default("member") // member | organizer
  months              Int       @default(1)
  durationLabel       String    @default("1 Month")
  discount            Float     @default(0)
  baseAmount          Float
  platformFee         Float
  memberPays          Float
  organizerGets       Float     @default(0)
  moderatorOwed       Float     @default(0)
  paymentStatus       String    @default("pending") // pending | confirmed | expired
  joinedAt            DateTime  @default(now())
  expiresAt           DateTime?
  expiryNotifications String[]  @default([])

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

// ─── Payments ─────────────────────────────────────────────────────────────
model Payment {
  id             String    @id @default(uuid())
  groupId        String
  memberId       String
  userId         String
  memberName     String
  months         Int       @default(1)
  amount         Float // total paid by member (USD)
  platformFee    Float
  moderatorOwed  Float
  organizerGets  Float     @default(0) // alias for moderatorOwed
  moderatorId    String?
  method         String    @default("pesapal")
  pesapalOrderId String?
  payoutStatus   String    @default("pending") // pending | paid
  paidAt         DateTime?
  paidBy         String?
  currency       String    @default("KES")
  confirmedAt    DateTime?
  createdAt      DateTime  @default(now())

  // Relations
  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation("UserPayments", fields: [userId], references: [id])

  @@map("payments")
}

// ─── PesaPal Orders ───────────────────────────────────────────────────────
model PesapalOrder {
  id              String    @id
  orderTrackingId String?
  groupId         String
  memberId        String
  userId          String
  memberName      String
  memberEmail     String
  months          Int       @default(1)
  baseAmount      Float     @default(0)
  platformFee     Float     @default(0)
  moderatorOwed   Float     @default(0)
  organizerGets   Float     @default(0)
  moderatorId     String?
  memberPays      Float
  chargedAmount   Float
  currency        String    @default("KES")
  status          String    @default("PENDING") // PENDING | COMPLETED | FAILED
  pesapalStatus   String?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  // Relations
  group Group @relation(fields: [groupId], references: [id])

  @@map("pesapal_orders")
}

// ─── Platform Earnings ────────────────────────────────────────────────────
model PlatformEarning {
  id       String   @id @default(uuid())
  orderId  String
  groupId  String
  fee      Float
  currency String   @default("KES")
  earnedAt DateTime @default(now())

  // Relations
  group Group @relation(fields: [groupId], references: [id])

  @@map("platform_earnings")
}

// ─── Moderator Settings ───────────────────────────────────────────────────
model ModeratorSettings {
  id           String   @id @default(uuid())
  userId       String   @unique
  pesapalEmail String
  displayName  String   @default("")
  feePercent   Float    @default(8)
  updatedAt    DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("moderator_settings")
}

// ─── Moderator Payouts ────────────────────────────────────────────────────
model ModeratorPayout {
  id             String   @id @default(uuid())
  moderatorId    String
  moderatorName  String
  moderatorEmail String
  pesapalEmail   String
  amountPaid     Float
  currency       String   @default("KES")
  paymentIds     String[] // array of Payment IDs included
  paymentCount   Int
  notes          String   @default("")
  paidAt         DateTime @default(now())
  paidBy         String   @default("superadmin")
  weekEnding     DateTime @default(now())

  // Relations
  moderator User @relation("ModeratorPayouts", fields: [moderatorId], references: [id])

  @@map("moderator_payouts")
}

// ─── Credential Vault ─────────────────────────────────────────────────────
model GroupCredential {
  id          String   @id @default(uuid())
  groupId     String   @unique
  slots       Json // array of { slotNumber, label, username, password, note }
  generalNote String   @default("")
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_credentials")
}

// ─── Group Emails ─────────────────────────────────────────────────────────
model GroupEmail {
  id             String   @id @default(uuid())
  groupId        String
  groupName      String
  subject        String
  body           String
  senderName     String
  senderEmail    String
  recipientCount Int
  recipients     String[]
  sentAt         DateTime @default(now())
  sentBy         String?
  status         String   @default("sending") // sending | sent | failed
  sent           Int      @default(0)
  failed         Int      @default(0)

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_emails")
}

// ─── Newsletter ───────────────────────────────────────────────────────────
model NewsletterCampaign {
  id             String   @id @default(uuid())
  type           String   @default("newsletter") // newsletter | organizer-email
  subject        String
  body           String
  senderName     String   @default("")
  senderEmail    String   @default("")
  recipientCount Int      @default(0)
  recipients     String[]
  sentAt         DateTime @default(now())
  status         String   @default("logged")

  @@map("newsletter_campaigns")
}

// ─── Footer Subscribers ───────────────────────────────────────────────────
model FooterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("footer_subscribers")
}

// ─── Platform Settings ────────────────────────────────────────────────────
model PlatformSettings {
  id         Int   @id @default(1) // singleton row
  feePercent Float @default(8)

  @@map("platform_settings")
}
